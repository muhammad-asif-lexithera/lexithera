{
  "version": 2,
  "builds": [
    {
      "src": "nodejs/backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["nodejs/backend/public/**", "nodejs/backend/references/**"]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "nodejs/backend/server.js"
    }
  ]
}
